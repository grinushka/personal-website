{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": ["src/routeTree.gen.ts", "**/*.test.ts", "node_modules"],
    "include": ["src/**/*", ".vscode/*", "index.html", "vite.config.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 140,
    "lineEnding": "lf",
    "bracketSpacing": true
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "useAltText": "error",
        "useValidAnchor": "error",
        "useKeyWithClickEvents": "error",
        "useValidAriaProps": "error",
        "useValidAriaValues": "error",
        "useHeadingContent": "error",
        "useIframeTitle": "error"
      },
      "style": {
        "useBlockStatements": "error",
        "useShorthandArrayType": "error",
        "useTemplate": "error"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noEmptyInterface": "off"
      },
      "complexity": {
        "noUselessFragments": "error",
        "useSimplifiedLogicExpression": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "asNeeded",
      "trailingCommas": "all",
      "bracketSpacing": true
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": false
    }
  }
}
